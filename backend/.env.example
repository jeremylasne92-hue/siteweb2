# ============================================
# ECHO Backend — Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# Database
MONGO_URL=mongodb://localhost:27017
DB_NAME=echo_database

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# Frontend URL (for OAuth redirects)
FRONTEND_URL=http://localhost:5173

# Security (MUST change in production)
OAUTH_STATE_SECRET=change-me-in-production
UNSUBSCRIBE_SECRET=echo-unsubscribe-secret-change-me

# reCAPTCHA v3 (required in production)
RECAPTCHA_SECRET_KEY=

# Email — SendGrid (required in production)
SENDGRID_API_KEY=
EMAIL_FROM=mouvement.echo.france@gmail.com
EMAIL_REPLY_TO=mouvement.echo.france@gmail.com
EMAIL_FROM_NAME=Mouvement ECHO
EMAIL_ALERT_TO=mouvement.echo.france@gmail.com

# Booking URL (Google Calendar)
BOOKING_URL=https://calendar.app.google/GSpXrQq72uqWhhSx9

# AI Enrichment (Claude Haiku for Mediatheque)
ANTHROPIC_API_KEY=

# Environment: development | production
ENVIRONMENT=development
